// API endpoint paths from schema.endpoints[*].path
const (
	endpointGetBill  = "{schema.endpoints[GetBill].path}"
	endpointPayBill  = "{schema.endpoints[PayBill].path}"
	endpointCheckPay = "{schema.endpoints[CheckPay].path}"
	// oauth2 only:
	// endpointToken = "{schema.auth.oauth2.token_url}"
)

// Config holds connection and auth configuration.
// Credentials come from config.yaml only — never hardcoded.
type Config struct {
	Endpoint      string `mapstructure:"endpoint"`
	SkipVerifySSL bool   `mapstructure:"skip_verify_ssl"`

	// basic auth:
	// Username string `mapstructure:"username"`
	// Password string `mapstructure:"password"`

	// apikey:
	// APIKey       string `mapstructure:"api_key"`
	// APIKeyHeader string `mapstructure:"api_key_header"`

	// hmac:
	// SecretKey string `mapstructure:"secret_key"`

	// rsa:
	// PrivateKeyPath string `mapstructure:"private_key_path"`
	// PublicKeyPath  string `mapstructure:"public_key_path"`

	// oauth2:
	// RefreshToken string `mapstructure:"refresh_token"`
	// {other partner-specific oauth2 fields}
}

// Provider is the interface for all {partner_name} API operations.
// Add CheckBalance ONLY if schema has a CheckBalance endpoint.
type Provider interface {
	GetBill(ctx context.Context, req *providerEntity.GetBillDataRequest) (*providerEntity.GetBillDataResponse, error)
	PayBill(ctx context.Context, req *providerEntity.PayBillDataRequest) (*providerEntity.PayBillDataResponse, error)
	CheckPay(ctx context.Context, req *providerEntity.CheckPayDataRequest) (*providerEntity.CheckPayDataResponse, error)
}

type provider struct {
	conn      httpclient.IHttpClient
	cfg       *Config
	collector metrics.Egress

	// oauth2 token cache — protected by mu:
	// accessToken string
	// tokenExpiry time.Time
	// mu          sync.Mutex

	// rsa:
	// rsaUtils utils.RSAUtils
}

func NewProvider(cfg *Config, conn httpclient.IHttpClient, collector metrics.Egress) Provider {
	p := &provider{cfg: cfg, conn: conn, collector: collector}
	// rsa: p.rsaUtils = utils.NewRSAUtils(cfg.PrivateKeyPath, cfg.PublicKeyPath)
	return p
}

