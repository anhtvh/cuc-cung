# Copy thành .env rồi điền — KHÔNG commit .env (đã có trong .gitignore)

# IAM client credentials — lấy từ portal GreenNode (mục IAM / Service Account)
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# API key MaaS — lấy từ portal mục MaaS / API key (hoặc qua skill agentbase-llm)
MAAS_API_KEY=

# Endpoint đã xác minh trong design §1.3 — thường không cần đổi
MAAS_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn

# (optional) ép model cụ thể khi test tool-call; bỏ trống = lấy model đầu tiên trong pool
MODEL=

# Memory module (AgentBase) — tạo store 1 lần qua CLI, điền ID vào đây trước khi bật MEMORY_BACKEND=agentbase
# Xem hướng dẫn tạo store: bash .claude/skills/agentbase/scripts/memory.sh create ...
AGENTBASE_MEMORY_STORE_ID=
AGENTBASE_MEMORY_STRATEGY_ID=   # để trống nếu chỉ cần short-term history
