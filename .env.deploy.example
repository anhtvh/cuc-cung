# ─────────────────────────────────────────────────────────────────────────
# .env.deploy.example — biến môi trường để deploy Agent Hub lên AgentBase.
# Copy thành .env (hoặc inject từng biến vào container env). KHÔNG commit secret thật.
# Tên biến = tên field trong app/config.py viết HOA (không prefix).
# ─────────────────────────────────────────────────────────────────────────

# ===== BẮT BUỘC (thiếu là vỡ) ============================================

# --- MaaS (LLM) ---
MAAS_API_KEY=                 # Bearer token MaaS (auth_token). BẮT BUỘC.
MAAS_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn
LLM_PROVIDER=anthropic        # Plan A native tool-use. KHÔNG đổi trừ khi fallback OpenAI.
MODEL=minimax/minimax-m2.5    # model chính (master + agent con)
ROUTER_MODEL=google/gemma-4-31b-it   # model rẻ cho router/classify (đi OpenAI endpoint)

# --- Auth / Session ---
# ⚠️ QUAN TRỌNG NHẤT: secret cố định cho JWT cookie. KHÔNG để trống.
# Trống → app sinh secret ngẫu nhiên mỗi lần boot → container restart = MỌI user rớt về
# guest (mất tool tạo agent). Sinh 1 lần & giữ cố định:  python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=

# Google OAuth (đăng nhập). redirect_uri trong Google Console phải khớp GOOGLE_REDIRECT_BASE + /auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_BASE=https://<deployed-url>   # vd https://agent-hub-xxx.aiplatform.vngcloud.vn (KHÔNG có / cuối)

# Nhà quản lý (admin): được duyệt/sửa agent public. Email Google của bạn.
ADMIN_EMAIL=you@company.com

# Cookie secure: deploy chạy HTTPS → true (cookie chỉ gửi qua https).
COOKIE_SECURE=true


# ===== NÊN SET CHO DEMO / PRODUCTION =====================================

# Tắt self-test khi demo live: tiết kiệm credit + nhanh hơn (bỏ ~23s self_test mỗi lần tạo agent).
SELF_TEST_ENABLED=false

# Rate limit /chat mỗi user mỗi phút (0 = tắt). Production khuyến nghị 20 để chặn cạn credit.
RATE_LIMIT_PER_MINUTE=20

# Memory backend lưu lịch sử chat lên AgentBase Memory (thay vì SQLite local).
MEMORY_BACKEND=agentbase
AGENTBASE_MEMORY_STORE_ID=memory-82c99d4a-6de7-450a-bfaf-251324f188a4
AGENTBASE_MEMORY_STRATEGY_ID=          # để trống nếu chỉ cần short-term

# IAM credential gọi AgentBase Memory (lấy token).
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=

# Database: Dockerfile mặc định SQLite /app/data/hub.db (EPHEMERAL — mất khi redeploy nếu
# không mount volume). Bền vững: set Postgres DSN.
# DATABASE_URL=postgresql://user:pass@host:5432/agenthub


# ===== MCP GATEWAY (set SAU KHI deploy — xem CLAUDE.md mục 8) =============
# 1) PATCH target của gateway 'agent-hub-gw' về https://<deployed-url>/mcp
# 2) Set endpoint dưới đây → app dùng gateway thật thay DuckDuckGo local.
MCP_GATEWAY_ENDPOINT=          # vd https://gw-agent-hub-gw-111745.agentbase-gateway.aiplatform.vngcloud.vn
MCP_GATEWAY_TARGET=websearch   # tên target trên gateway
MCP_GATEWAY_SERVER_NAME=web-search
MCP_GATEWAY_SECRET=            # shared secret header X-Mcp-Secret cho /mcp (set khi public để chặn abuse)


# ===== TÙY CHỌN (đã có default hợp lý trong config.py — chỉ set khi cần đổi) ====
# MAX_TOKENS=16384             # trần output mỗi request (đã nâng cho reasoning model)
# BUILDER_SLA_SECONDS=240      # SLA riêng cho master tạo agent
# RESPONSE_SLA_SECONDS=55      # SLA chat agent con
# MAX_TOOL_ROUNDS=10
# GUEST_MODE=true              # false = bắt buộc đăng nhập mới vào được
# BUILDER_ENABLED=true         # false = tắt master factory (không cho tạo agent)
# ADMIN_USER_IDS=admin         # thêm admin theo user_id (ngoài ADMIN_EMAIL)
# ORCHESTRATION_MAX_AGENTS=4
# JWT_EXPIRE_HOURS=168
